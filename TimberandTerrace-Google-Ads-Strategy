<title>Google Ads Strategy — Timber &amp; Terrace</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --purple: #6b4423;        /* walnut (primary) */
    --purple-dark: #4d3018;
    --purple-deeper: #33200f;
    --teal: #6f9a5e;          /* sage accent */
    --white: #ffffff;
    --off-white: #f7f2ea;
    --gray-mid: #cdbba1;
    --text-dark: #2c2114;
    --red-alert: #c1492f;
    --amber: #c8862a;
    --green: #4f9d69;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', sans-serif; background: #f7f4ee; color: var(--text-dark); }

  /* COVER */
  .cover {
    background: var(--purple);
    min-height: 100vh;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 60px 40px;
    position: relative; overflow: hidden;
  }
  .cover::before {
    content: ''; position: absolute;
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(111,154,94,0.14) 0%, transparent 70%);
    top: -150px; right: -150px;
  }
  .cover::after {
    content: ''; position: absolute;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(51,32,15,0.7) 0%, transparent 70%);
    bottom: -100px; left: -100px;
  }
  .logo-ring {
    width: 80px; height: 80px; border-radius: 50%;
    border: 2px solid rgba(111,154,94,0.5);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 32px; font-size: 28px; color: var(--teal);
    position: relative; z-index: 1;
  }
  .cover-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--teal);
    margin-bottom: 16px; position: relative; z-index: 1;
  }
  .cover h1 {
    font-size: clamp(36px, 7vw, 72px); font-weight: 900;
    line-height: 1.05; letter-spacing: -0.02em;
    position: relative; z-index: 1; margin-bottom: 8px; color: #fff;
  }
  .cover h1 span { color: var(--teal); }
  .cover-sub { font-size: 18px; font-weight: 300; color: rgba(255,255,255,0.7); margin-top: 12px; position: relative; z-index: 1; }
  .cover-chips { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 36px; position: relative; z-index: 1; }
  .cover-chip { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.18); border-radius: 100px; padding: 7px 18px; font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.85); }

  /* NAV */
  .nav { background: #ffffff; border-bottom: 1px solid #e6ddcd; padding: 0 40px; display: flex; justify-content: center; overflow-x: auto; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 4px rgba(0,0,0,0.06); scrollbar-width: none; -ms-overflow-style: none; }
  .nav::-webkit-scrollbar { display: none; }
  .nav a { display: inline-block; padding: 16px 20px; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #8a7a62; text-decoration: none; border-bottom: 2px solid transparent; white-space: nowrap; transition: all 0.2s; }
  .nav a:hover { color: var(--purple); border-bottom-color: var(--purple); }

  /* SECTIONS */
  .s-dark { background: #f7f4ee; padding: 64px 40px; color: var(--text-dark); }
  .s-light { background: #ffffff; padding: 64px 40px; color: var(--text-dark); }
  .s-mid { background: #f1eae0; padding: 64px 40px; color: var(--text-dark); }
  .inner { max-width: 960px; margin: 0 auto; }

  /* HEADERS */
  .stag { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--purple); margin-bottom: 12px; }
  .stag::before { content: ''; width: 24px; height: 2px; background: var(--purple); border-radius: 2px; }
  h2 { font-size: clamp(22px, 3.5vw, 34px); font-weight: 800; line-height: 1.15; letter-spacing: -0.01em; margin-bottom: 16px; color: var(--text-dark); }
  .intro { font-size: 15px; line-height: 1.7; max-width: 100%; margin-bottom: 40px; color: #5e5340; }

  /* 2-COL */
  .c2 { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  @media(max-width:640px) { .c2 { grid-template-columns: 1fr; } }

  /* WHITE CARD */
  .wc { background: #ffffff; border: 1px solid #e6ddcd; border-radius: 16px; padding: 28px; color: var(--text-dark); }
  .wc h3 { font-size: 18px; font-weight: 800; color: var(--text-dark); margin-bottom: 10px; letter-spacing: -0.01em; }
  .wc p { font-size: 14px; color: #5e5340; line-height: 1.65; margin-bottom: 18px; }

  /* TAGS */
  .tag { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; margin-bottom: 14px; }
  .tag.t { background: rgba(111,154,94,0.18); color: #4d7a3c; border: 1px solid rgba(111,154,94,0.4); }
  .tag.g { background: rgba(79,157,105,0.15); color: var(--green); border: 1px solid rgba(79,157,105,0.3); }
  .tag.a { background: rgba(200,134,42,0.15); color: var(--amber); border: 1px solid rgba(200,134,42,0.35); }

  /* CHECKLIST */
  .ck { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .ck li { display: flex; gap: 10px; font-size: 13.5px; color: #4a4030; line-height: 1.5; align-items: flex-start; }
  .ck li::before { content: '✓'; flex-shrink: 0; width: 18px; height: 18px; border-radius: 50%; background: rgba(111,154,94,0.18); color: #4d7a3c; font-size: 10px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-top: 1px; }
  .ck.todo li::before { content: '○'; background: rgba(200,134,42,0.15); color: var(--amber); }

  /* TABLE */
  .tw { border-radius: 14px; overflow: hidden; border: 1px solid #e6ddcd; }
  .th { padding: 18px 24px 14px; background: var(--purple); }
  .th h3 { font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
  .th p { font-size: 12px; color: var(--gray-mid); }
  table { width: 100%; border-collapse: collapse; }
  thead th { padding: 11px 20px; font-size: 11px !important; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #8a7a62; text-align: left; background: #f3eee3; border-bottom: 1px solid #e6ddcd; }
  tbody td { padding: 13px 20px; font-size: 13.5px; color: #3a3122; border-bottom: 1px solid #f0ebe0; vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  .tdl { font-weight: 600; color: var(--text-dark); }
  .tdt { font-weight: 700; color: var(--purple); }
  .ttr td { background: rgba(107,68,35,0.05) !important; border-top: 2px solid rgba(107,68,35,0.2) !important; font-size: 15px; }
  .tw table + table { border-top: 2px solid #e6ddcd; }
  .tw table + table thead th { background: #ede6d8; }

  /* STEPS */
  .sg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .sc { background: #ffffff; border: 1px solid #e6ddcd; border-radius: 14px; padding: 22px 20px; }
  .sn { font-size: 28px; font-weight: 900; color: var(--purple); line-height: 1; margin-bottom: 10px; opacity: 0.3; }
  .sc h4 { font-size: 14px; font-weight: 700; margin-bottom: 6px; color: var(--text-dark); }
  .sc p { font-size: 13px; line-height: 1.55; color: #5a503d; }
  @media(max-width:860px) { .sg { grid-template-columns: repeat(2, 1fr); } }
  @media(max-width:520px) { .sg { grid-template-columns: 1fr; } }

  /* CALLOUT */
  .co { background: #f1eae0; border: 1px solid #e6ddcd; border-radius: 14px; padding: 28px 32px; display: flex; gap: 20px; align-items: flex-start; margin-top: 24px; }
  .co.w { background: #fbf5e8; border-color: #e8cf92; }
  .co.d { background: var(--purple); border-color: rgba(255,255,255,0.1); }
  .co.d h3 { color: #ffffff; }
  .co.d p { color: rgba(255,255,255,0.8); }
  .co.d strong { color: #ffffff; }
  .ci { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
  .co h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 6px; }
  .co p { font-size: 14px; color: #5e5340; line-height: 1.65; }
  .co strong { color: var(--text-dark); }
  .c2 > .co { height: 100%; }

  /* ROI / METRICS */
  .rr { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 24px; }
  @media(max-width:640px) { .rr { grid-template-columns: 1fr; } }
  .rc { background: #ffffff; border: 1px solid #e6ddcd; border-radius: 14px; padding: 24px 20px; text-align: center; box-shadow: 0 2px 6px rgba(107,68,35,0.05); }
  .rb { font-size: 38px; font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 8px; color: var(--purple); }
  .rb.a { color: var(--amber); }
  .rb.g { color: var(--green); }
  .rc p { font-size: 13px; color: #5a503d; line-height: 1.4; }
  .rc span { display: block; font-size: 11px; color: #9a8a70; margin-top: 4px; }

  /* KEYWORD PILLS */
  .kw { display: flex; flex-wrap: wrap; gap: 8px; margin: 4px 0 8px; }
  .kw span { background: #f3eee3; border: 1px solid #e6ddcd; border-radius: 8px; padding: 6px 11px; font-size: 12.5px; color: #4a4030; font-weight: 500; }
  .kw.ex span { background: rgba(107,68,35,0.07); border-color: rgba(107,68,35,0.2); color: var(--purple); font-weight: 600; }
  .kw.neg span { background: rgba(193,73,47,0.07); border-color: rgba(193,73,47,0.2); color: var(--red-alert); }
  .lbl { font-size: 11px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #8a7a62; margin: 16px 0 4px; }

  /* FOOTER */
  .foot { background: #f1eae0; padding: 40px; text-align: left; font-size: 12px; color: #8a7a62; border-top: 1px solid #e6ddcd; line-height: 1.7; }

  @media(max-width:640px) {
    .s-dark, .s-light, .s-mid { padding: 48px 20px; }
    .nav { padding: 0 16px; }
    .foot { padding: 32px 20px; }
    .co { padding: 20px; gap: 14px; }
    .tw .th { padding: 14px 16px 12px; }
    thead th, tbody td { padding-left: 14px; padding-right: 14px; }
  }
</style>
</head>
