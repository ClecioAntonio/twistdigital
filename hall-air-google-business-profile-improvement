  /* TAGS */
  .tag { display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; margin-bottom: 14px; }
  .tag.t { background: rgba(0,196,180,0.15); color: var(--teal); border: 1px solid rgba(0,196,180,0.3); }
  .tag.g { background: rgba(0,196,122,0.15); color: var(--green); border: 1px solid rgba(0,196,122,0.3); }
  .tag.a { background: rgba(255,184,48,0.15); color: var(--amber); border: 1px solid rgba(255,184,48,0.3); }
  .tag.r { background: rgba(255,77,106,0.12); color: var(--red-alert); border: 1px solid rgba(255,77,106,0.3); }

  /* CHECKLIST */
  .ck { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .ck li { display: flex; gap: 10px; font-size: 13.5px; color: #3a4070; line-height: 1.5; align-items: flex-start; }
  .ck li::before { content: '✓'; flex-shrink: 0; width: 18px; height: 18px; border-radius: 50%; background: rgba(0,196,180,0.15); color: var(--teal); font-size: 10px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-top: 1px; }

  /* TABLE */
  .tw { border-radius: 14px; overflow: hidden; border: 1px solid #dde2f0; }
  .th { padding: 18px 24px 14px; background: var(--purple); border-bottom: 1px solid transparent; }
  .th h3 { font-size: 16px; font-weight: 700; color: var(--white); margin-bottom: 2px; }
  .th p { font-size: 12px; color: var(--gray-mid); }
  table { width: 100%; border-collapse: collapse; }
  thead th { padding: 11px 20px; font-size: 11px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #6670a0; text-align: left; background: #f5f7ff; border-bottom: 1px solid #dde2f0; }
  tbody td { padding: 13px 20px; font-size: 13.5px; color: #2a3060; border-bottom: 1px solid #eef0f8; vertical-align: middle; }
  tbody tr:last-child td { border-bottom: none; }
  .tdl { font-weight: 600; color: var(--text-dark); }
  .tdt { font-weight: 700; color: var(--purple); }
  .ttr td { background: rgba(45,35,160,0.05) !important; border-top: 2px solid rgba(45,35,160,0.2) !important; font-size: 15px; }

  /* STEPS */
  .sg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .sc { background: #ffffff; border: 1px solid #dde2f0; border-radius: 14px; padding: 22px 20px; }
  .sn { font-size: 28px; font-weight: 900; color: var(--purple); line-height: 1; margin-bottom: 10px; opacity: 0.3; }
  .sc h4 { font-size: 14px; font-weight: 700; margin-bottom: 6px; color: var(--text-dark); }
  .sc p { font-size: 13px; line-height: 1.55; color: #5a6290; }

  /* CALLOUT */
  .co { background: #f0f2f8; border: 1px solid #dde2f0; border-radius: 14px; padding: 28px 32px; display: flex; gap: 20px; align-items: flex-start; margin-top: 24px; }
  .co.w { background: #fffbf0; border-color: #f5d87a; }
  .co.d { background: var(--purple); border-color: rgba(255,255,255,0.1); }
  .co.d h3 { color: #ffffff; }
  .co.d p { color: rgba(255,255,255,0.75); }
  .co.d strong { color: #ffffff; }
  .co.r { background: rgba(255,77,106,0.06); border-color: rgba(255,77,106,0.25); }
  .co.r h3 { color: var(--red-alert); }
  .ci { font-size: 24px; flex-shrink: 0; margin-top: 2px; }
  .co h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 6px; }
  .co p { font-size: 14px; color: #4a5280; line-height: 1.65; }
  .co strong { color: var(--text-dark); }

  /* ROI METRICS */
  .rr { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; margin-bottom: 40px; }
  @media(max-width:640px) { .rr { grid-template-columns: 1fr; } }
  .rc { background: #ffffff; border: 1px solid #dde2f0; border-radius: 14px; padding: 24px 20px; text-align: center; box-shadow: 0 2px 6px rgba(45,35,160,0.05); }
  .rb { font-size: 38px; font-weight: 900; letter-spacing: -0.03em; line-height: 1; margin-bottom: 8px; color: var(--purple); }
  .rb.a { color: var(--amber); }
  .rb.g { color: var(--green); }
  .rb.r { color: var(--red-alert); }
  .rc p { font-size: 13px; color: #5a6290; line-height: 1.4; }
  .rc span { display: block; font-size: 11px; color: #8890b0; margin-top: 4px; }

  /* FOOTER */
  .foot { background: #f0f2f8; padding: 40px 40px; text-align: left; font-size: 12px; color: #6670a0; border-top: 1px solid #dde2f0; }

  @media(max-width:860px) { .sg { grid-template-columns: repeat(2, 1fr); } }
