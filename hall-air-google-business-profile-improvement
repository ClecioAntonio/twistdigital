    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center; padding: 60px 40px;
    position: relative; overflow: hidden;
  }
  .cover::before {
    content: ''; position: absolute;
    width: 600px; height: 600px; border-radius: 50%;
    background: radial-gradient(circle, rgba(0,196,180,0.12) 0%, transparent 70%);
    top: -150px; right: -150px;
  }
  .cover::after {
    content: ''; position: absolute;
    width: 400px; height: 400px; border-radius: 50%;
    background: radial-gradient(circle, rgba(22,15,92,0.7) 0%, transparent 70%);
    bottom: -100px; left: -100px;
  }
  .logo-ring {
    width: 80px; height: 80px; border-radius: 50%;
    border: 2px solid rgba(0,196,180,0.4);
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 32px; font-size: 32px;
    position: relative; z-index: 1;
  }
  .cover-tag {
    font-size: 11px; font-weight: 600; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--teal);
    margin-bottom: 16px; position: relative; z-index: 1;
  }
  .cover h1 {
    font-size: clamp(36px, 7vw, 72px); font-weight: 900;
    line-height: 1.05; letter-spacing: -0.02em;
    position: relative; z-index: 1; margin-bottom: 8px;
    color: white;
  }
  .cover h1 span { color: var(--teal); }
  .cover-sub { font-size: 18px; font-weight: 300; color: rgba(255,255,255,0.6); margin-top: 12px; position: relative; z-index: 1; }
  .cover-chips { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-top: 36px; position: relative; z-index: 1; }
  .cover-chip { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15); border-radius: 100px; padding: 7px 18px; font-size: 13px; font-weight: 500; color: rgba(255,255,255,0.8); }

  /* NAV */
  .nav { background: #ffffff; border-bottom: 1px solid #dde2f0; padding: 0 40px; display: flex; justify-content: center; overflow-x: auto; position: sticky; top: 0; z-index: 100; box-shadow: 0 1px 4px rgba(0,0,0,0.06); scrollbar-width: none; -ms-overflow-style: none; }
  .nav::-webkit-scrollbar { display: none; }
  .nav a { display: inline-block; padding: 16px 20px; font-size: 12px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: #6670a0; text-decoration: none; border-bottom: 2px solid transparent; white-space: nowrap; transition: all 0.2s; }
  .nav a:hover { color: var(--purple); border-bottom-color: var(--purple); }

  /* SECTIONS */
  .s-dark { background: #f8f9fc; padding: 64px 40px; color: var(--text-dark); }
  .s-light { background: #ffffff; padding: 64px 40px; color: var(--text-dark); }
  .s-mid { background: #f0f2f8; padding: 64px 40px; color: var(--text-dark); }
