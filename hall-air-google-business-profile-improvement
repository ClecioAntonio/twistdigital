  /* HEADERS */
  .stag { display: inline-flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--purple); margin-bottom: 12px; }
  .stag::before { content: ''; width: 24px; height: 2px; background: var(--purple); border-radius: 2px; }
